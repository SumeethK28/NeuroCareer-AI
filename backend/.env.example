# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL Connection String
# Local: postgresql://postgres:password@localhost:5432/neurocareer
# Neon: postgresql://user:password@ep-xxxxx.region.neon.tech/neurocareer?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/neurocareer

# ============================================
# AUTHENTICATION
# ============================================

# JWT Secret Key - Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# GROQ LLM CONFIGURATION
# ============================================

# Get API key from: https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here

# Do not change - this is the model specified for the hackathon
GROQ_MODEL=qwen/qwen3-32b

# Do not change - this is Groq's OpenAI-compatible endpoint
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Timeout for LLM requests (increase if you have slow internet)
GROQ_TIMEOUT_SECONDS=30

# ============================================
# HINDSIGHT MEMORY CONFIGURATION
# ============================================

# Get API key from: https://hindsight.is
HINDSIGHT_API_KEY=your_hindsight_api_key_here

# Hindsight API endpoint
HINDSIGHT_BASE_URL=https://api.hindsight.is

# ============================================
# FRONTEND URL (for CORS)
# ============================================

FRONTEND_URL=http://localhost:3000

# ============================================
# ENVIRONMENT
# ============================================

# development, staging, production
ENVIRONMENT=development

# Enable debug mode (set to false in production)
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

